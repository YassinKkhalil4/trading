# Autonomous Trading Intelligence Platform
# Default is research. Never default to live.
ENVIRONMENT_MODE=research
APP_NAME=Autonomous Trading Intelligence Platform
DEPLOYMENT_TARGET=local
AWS_REGION=us-east-1

# Local database. SQLite makes the dashboard functional immediately.
DATABASE_URL=sqlite:///trading_system.db
REDIS_URL=redis://localhost:6379/0

# Decision support is deterministic/offline by default. External providers are disabled in v1.
DECISION_SUPPORT_PROVIDER=deterministic
EXTERNAL_DECISION_SUPPORT_ENABLED=false

# PostgreSQL remains the production target once a local server is configured.
# DATABASE_URL=postgresql+psycopg://trading:trading@localhost:5432/trading_system

# Paper trading is enabled by default. Live execution is code-capable but gated off.
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_DATA_URL=https://data.alpaca.markets
ALPACA_MARKET_DATA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex
ALPACA_MARKET_DATA_FEED=iex
ALPACA_PRIMARY_DATA_FEED=iex
ALPACA_STREAM_SYMBOLS=SPY,QQQ,AMD,NVDA,TSLA
ALPACA_STREAM_CHANNELS=bars,quotes,trades,statuses
ALPACA_STREAM_MAX_RECONNECTS=10
ALPACA_BARS_TIMEFRAME=1Min
ALPACA_BARS_LIMIT=1000

# Admin access. Set ADMIN_PASSWORD and API_ADMIN_TOKEN in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=change-me
API_ADMIN_TOKEN=
AUTH_SESSION_MINUTES=480
ADMIN_FAILED_LOGIN_LOCKOUT_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=15

# Live trading keys are intentionally commented out and disabled by default.
# ALPACA_LIVE_API_KEY=
# ALPACA_LIVE_SECRET_KEY=
# ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
# ALPACA_LIVE_DATA_URL=https://data.alpaca.markets
# ALLOW_LIVE_TRADING=false
# CONFIRM_LIVE_TRADING=
# ENABLE_LIVE_ORDER_PATH=false
# LIVE_READINESS_MAX_AGE_MINUTES=60
# LIVE_APPROVAL_MAX_AGE_MINUTES=240

# Enrichment providers only.
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
NEWS_RSS_FEEDS=https://feeds.finance.yahoo.com/rss/2.0/headline?s={symbol}&region=US&lang=en-US

# SEC fair-access identity. Replace with your real name/company and contact email.
SEC_USER_AGENT=AutonomousTradingIntelligence contact@example.com
SEC_REQUESTS_PER_SECOND=5

# Dashboard refresh interval.
DASHBOARD_REFRESH_SECONDS=15

# Scheduled collector cadence.
SCHEDULER_MARKET_DATA_SECONDS=60
SCHEDULER_FILL_RECONCILIATION_SECONDS=30
SCHEDULER_SEC_SECONDS=3600
SCHEDULER_NEWS_SECONDS=300
SCHEDULER_REGIME_SECONDS=60
SCHEDULER_CATALYST_SECONDS=300
SCHEDULER_TRADE_MONITOR_SECONDS=15
SCHEDULER_REVIEW_SECONDS=3600
PROVIDER_HEALTH_MAX_AGE_SECONDS=180
WORKER_SLEEP_SECONDS=5
SCHEDULER_LOCK_TTL_SECONDS=300

# Risk defaults for paper mode.
RISK_PER_TRADE_PCT=0.25
MAX_DAILY_LOSS_PCT=1.0
MAX_WEEKLY_LOSS_PCT=3.0
MAX_OPEN_POSITIONS=3
MAX_SINGLE_SECTOR_EXPOSURE_PCT=30.0
MAX_SYMBOL_EXPOSURE_PCT=20.0
MAX_STRATEGY_EXPOSURE_PCT=40.0
MAX_CORRELATED_EXPOSURE_PCT=50.0
MAX_OVERNIGHT_EXPOSURE_PCT=50.0
MAX_TRADES_PER_DAY=5
MAX_TRADES_PER_STRATEGY_PER_DAY=2
MAX_SLIPPAGE_BPS=25.0
MAX_ORDER_STALE_SECONDS=120
QUOTE_FRESHNESS_MAX_SECONDS=5
BAR_FRESHNESS_MAX_SECONDS=90

# Liquidity gates.
MIN_PRICE=5.0
MIN_AVERAGE_VOLUME=1000000
MIN_DOLLAR_VOLUME=20000000
MAX_SPREAD_BPS=20.0
